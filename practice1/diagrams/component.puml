@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Диаграмма компонентов контейнера «Графический интерфейс»

' Персона
Person(пользователь, "Пользователь", "Художник, геймдизайнер или любитель,\nсоздающий персонажей")

' Внешние контейнеры и системы (для контекста взаимодействия)
Container(renderer, "Движок рендеринга", "Отвечает за наложение слоёв,\nHSV и трансформации")
Container(params_mgr, "Менеджер параметров", "Сериализация/десериализация\nпараметров персонажа")
System_Ext(экспорт, "Система экспорта", "Сохранение готового изображения")

' ----- Компоненты, составляющие контейнер "Графический интерфейс" -----
Component(viewport, "Область предпросмотра", "React / Qt Widget", "Отображает текущий результат\nрендеринга. Позволяет перетаскивать\nслои мышью.")
Component(layers_panel, "Панель слоёв", "React / Qt List", "Список всех слоёв с возможностью:\n— изменения порядка (drag-n-drop)\n— скрытия/показа\n— выбора активного слоя")
Component(properties_panel, "Панель свойств", "React / Qt Form", "Настройки выбранного слоя:\n— HSV-коррекция (ползунки)\n— позиция X/Y\n— альтернативный вариант\n— прозрачность")
Component(toolbar, "Панель инструментов", "React / Qt Toolbar", "Кнопки быстрого доступа:\nСохранить, Загрузить,\nЭкспорт, Отменить/Повторить,\nСбросить все параметры")
Component(asset_selector, "Выбор альтернатив", "React / Qt Dropdown + Grid", "Показывает все доступные варианты\nдля текущей части тела (голова, торс,\nруки, ноги, одежда).")
Component(state_manager, "Локальный стейт-менеджер", "Redux / MobX / Qt Model", "Хранит временное состояние UI\n(выбранный слой, режимы, кэш предпросмотра).\nСинхронизируется с Менеджером параметров.")

' ----- Отношения пользователя с компонентами UI -----
Rel(пользователь, viewport, "Перетаскивает слои,\nкликает по элементам", "Mouse events")
Rel(пользователь, layers_panel, "Изменяет порядок,\nвыбирает слой", "Drag & drop, клик")
Rel(пользователь, properties_panel, "Регулирует цвет, позицию,\nвыбирает альтернативы", "Слайдеры, поля ввода")
Rel(пользователь, toolbar, "Нажимает кнопки", "Клик")
Rel(пользователь, asset_selector, "Выбирает вариант\nиз библиотеки", "Клик по превью")

' ----- Внутренние взаимосвязи компонентов UI -----
Rel(viewport, state_manager, "Запрашивает текущее состояние\nвсех параметров для отрисовки", "Чтение")
Rel(layers_panel, state_manager, "Обновляет порядок слоёв,\nвыбранный слой", "Вызов actions")
Rel(properties_panel, state_manager, "Обновляет свойства\nактивного слоя", "Вызов actions")
Rel(asset_selector, state_manager, "Обновляет вариант слоя", "Вызов actions")
Rel(toolbar, state_manager, "Запускает команды\n(сохранить, загрузить,\nэкспорт, сброс)", "Команды")

Rel(state_manager, params_mgr, "Загружает/сохраняет\nпараметры", "API сериализации")
Rel(state_manager, viewport, "Уведомляет о необходимости\nперерисовки", "Сигнал / событие")

' ----- Связи UI с внешними контейнерами/системами -----
Rel(viewport, renderer, "Передаёт актуальные параметры\nслоёв для рендеринга", "Вызов отрисовки")
Rel(renderer, viewport, "Возвращает растровое изображение\nдля предпросмотра", "Callback")

Rel(state_manager, экспорт, "Команда экспорта\n(через toolbar)", "Передаёт итоговое изображение")

Rel(asset_selector, params_mgr, "Запрашивает список доступных\nальтернатив для части тела", "Запрос метаданных")
@enduml
