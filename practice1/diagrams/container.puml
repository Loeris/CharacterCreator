@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Диаграмма контейнеров системы «Редактор персонажей»

' Персона (тот же пользователь)
Person(пользователь, "Пользователь", "Художник, геймдизайнер или любитель,\nсоздающий персонажей")

' ----- Контейнеры нашей системы -----

Container(ui, "Графический интерфейс", "Electron / Qt / Tk", "Обеспечивает визуальное редактирование:\nотображение слоёв, панели управления,\nпредпросмотр результата")

Container(renderer, "Движок рендеринга", "C++ / Python + PIL/OpenGL", "Накладывает слои с учётом прозрачности,\nприменяет HSV-преобразования,\nтрансформации (перемещение, масштабирование),\nгенерирует итоговое изображение")

Container(params, "Менеджер параметров", "JSON / YAML\nсериализатор", "Загружает и сохраняет параметры персонажа:\nвыбранные варианты слоёв,\nпозиции, HSV-коррекции,\nпорядок наложения")

Container(local_assets, "Локальное хранилище слоёв", "Файловая система + метаданные", "Кэширует оригинальные изображения слоёв\n(части тела, одежда, аксессуары)\nи их альтернативные варианты")

' ----- Внешние системы (уже были) -----
System_Ext(фс, "Файловая система", "Хранение файлов параметров персонажей\n(JSON / XML / custom format)")

System_Ext(библиотека_слоёв, "Библиотека слоёв", "Хранилище исходных изображений слоёв\n(части тела, одежда, аксессуары,\nальтернативные варианты)")

System_Ext(экспорт, "Система экспорта", "Сохранение готового изображения\n(PNG / JPEG)")

' ----- Отношения между контейнерами и внешними системами -----

Rel(пользователь, ui, "Использует", "Клик, перетаскивание,\nвыбор параметров")

Rel(ui, renderer, "Запрашивает отрисовку\n(передаёт параметры слоёв)", "Вызов функции / IPC")
Rel(renderer, ui, "Возвращает готовый холст", "Растровое изображение")

Rel(ui, params, "Читает/обновляет параметры\nтекущего персонажа", "API сериализации")
Rel(params, ui, "Уведомляет об изменении\nпараметров", "Событие")

Rel(renderer, local_assets, "Запрашивает оригиналы слоёв\nпо идентификаторам", "Чтение PNG/JPEG")
Rel(local_assets, renderer, "Отдаёт изображения", "Поток данных")

Rel(params, фс, "Сохраняет параметры в", "Сериализация")
Rel(params, фс, "Загружает параметры из", "Десериализация")

Rel(local_assets, библиотека_слоёв, "Подтягивает отсутствующие слои из", "Загрузка по сети/диску")
Rel(библиотека_слоёв, local_assets, "Отдаёт копии ассетов", "Файловая передача")

Rel(renderer, экспорт, "Экспортирует финальное\nизображение в", "PNG/JPEG")

' Дополнительно: связь пользователя с экспортом (опционально)
Rel(пользователь, экспорт, "Инициирует сохранение\nчерез UI", "Команда")
@enduml
