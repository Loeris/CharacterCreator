@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

' Устанавливаем заголовок
title Диаграмма контекста системы «Редактор персонажей»

' Персонажи (люди)
Person(пользователь, "Пользователь", "Художник, геймдизайнер или любитель,\nсоздающий персонажей")

' Система, которую описываем
System(редактор, "Редактор персонажей", "Программа для создания изображений персонажей\nпутём наложения слоёв с частями тела и одежды")

' Внешние системы
System_Ext(фс, "Файловая система", "Хранение файлов параметров персонажей\n(JSON / XML / custom format)")

System_Ext(библиотека_слоёв, "Библиотека слоёв", "Хранилище исходных изображений слоёв\n(части тела, одежда, аксессуары)")

' Отношения
Rel(пользователь, редактор, "Использует", "Интерактивный интерфейс")

Rel(редактор, библиотека_слоёв, "Загружает слои из", "Чтение PNG/JPEG")
Rel(редактор, библиотека_слоёв, "Получает альтернативные варианты", "Чтение метаданных")

Rel(редактор, фс, "Сохраняет параметры персонажа в", "Сериализация")
Rel(редактор, фс, "Загружает параметры персонажа из", "Десериализация")

' Опционально: внешняя система для экспорта
System_Ext(экспорт, "Система экспорта", "Сохранение готового изображения")

Rel(редактор, экспорт, "Экспортирует готовый образ", "PNG/JPEG")
@enduml
